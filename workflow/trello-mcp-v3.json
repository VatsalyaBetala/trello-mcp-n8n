        "url": "https://api.trello.com/1/members/me/boards",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "trelloApi",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "fields",
              "value": "id,name,url,shortUrl,closed"
            },
            {
              "name": "filter",
              "value": "={{ $fromAI(\"filter\", \"Which boards to return: open (default), all to include closed boards, or closed for only archived.\", \"string\", \"open\") }}"
